---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import 'bootstrap-icons/font/bootstrap-icons.min.css';
import '../styles/variables.css';
 
interface Props {
	lang: string
	title: string
	header: {
		about: string
		projects: string
		contact: string
		modo: {
			light: string
			dark: string
			system: string
			search: string
		}
		language: {
			english: string
			spanish: string
			search: string
		}
	}
	footer: {
		text: string
	}
}

const { lang, title, header, footer } = Astro.props;
---


<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="author" content="Wilber Hernández">
		<meta name="description" content="Desarrollador web junior con experiencia en HTML, CSS, JavaScript, Astro, React y más. Explora mi portafolio y proyectos.">
		<meta name="keywords" content="desarrollador web, frontend, backend, Astro, React, JavaScript, Node.js, TypeScript, portafolio">
		<meta name="robots" content="index, follow">

		<meta property="og:title" content="Wilber Hernández - Desarrollador Web">
		<meta property="og:description" content="Desarrollador web especializado en Astro, React y más. Descubre mis proyectos.">
		<meta property="og:image" content="URL_de_tu_imagen">
		<meta property="og:url" content="https://tudominio.com">
		<meta property="og:type" content="website">


		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
      href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@100..700&family=Rubik:wght@800&display=swap"
      rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body >
		<div class="background"></div>
		<Header header={header} />
		<slot />
		<Footer footer={footer} />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	html {
		scroll-behavior: smooth;
	}


	body {
		color: var(--text-color)
	}

	.background {
		position: fixed;
		z-index: -100;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background-color: var(--background-color);
		background-image: var(--background-image);
	}

	.section-text-paragraph {
    text-align: center;
    color: var(--section-text-paragraph);
    font-size: 17px;
		font-family: "Roboto Mono", monospace;
  }

  .section-title {
    font-size: 3rem;
    color: var(--text-color);
    font-weight: bold;
		font-family: "Rubik", sans-serif;
  }

</style>
